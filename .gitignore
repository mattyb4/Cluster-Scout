# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# ── Editor / tool configs ────────────────────────────────────────────────
.vscode/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store

# ── User-provided input data (uploaded via the app or placed manually) ────
data/input/cosmic/
data/input/ptmd/
data/cif_comparison/

# 14-3-3 confirmed interactors: NOT user-provided — small, rarely-updated
# reference data bundled with the app (see data/input/1433_interactors/).

# ── Machine-generated API caches (regenerated/extended automatically) ─────
data/cache/

# ── AlphaFold structure models (large binary files, re-downloadable via step 2) ──
cif_models/
*.cif

# ── Pipeline intermediate data (regenerated by step 1 each run) ───────────
data/steps/

# ── Pipeline outputs (regenerated each run) ────────────────────────────────
Output/ptm_mutation_proximity_db.tsv
Output/ptm_mutation_proximity_long.tsv
Output/mutation_cluster_db.tsv
Output/radius_sweep.*
Output/*.png
Output/coordinates/
Output/cif_variance/
*.bak

# ── Pipeline logs (regenerated each run) ───────────────────────────────────
Output/logs/download_report.tsv
Output/logs/download_errors.tsv
Output/logs/ptm_skipped.tsv
Output/logs/mutation_cluster_skipped.tsv
Output/logs/ptm_genes_without_cosmic_mutations.tsv
Output/logs/pipeline_runtimes.json
Output/logs/results_column_prefs.json
